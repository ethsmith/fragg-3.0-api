# Copy this file to .env and fill in real values for local development.
# In production on Vercel, these are injected by the MongoDB Atlas integration.

# Full MongoDB Atlas connection string, e.g.:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Optional: name of the database to use. If omitted, it must be present in the URI.
MONGODB_DATABASE=

# Optional: HTTP port for local dev (defaults to 3000).
PORT=3000

# Shared secret required for all POST endpoints (player-stats ingest).
# Generate with: openssl rand -hex 32
# Set this in Vercel Project Settings -> Environment Variables for each
# environment (Production / Preview / Development).
API_KEY=
