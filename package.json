{
  "name": "fragg-3.0-api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node ./dist/src/bin/www.js",
    "dev": "ts-node-dev --respawn --transpile-only ./src/bin/www.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^16.4.5",
    "express": "~4.16.1",
    "mongoose": "^8.3.0",
    "morgan": "~1.9.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.30",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
